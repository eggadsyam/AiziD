{
  "name": "gabungin-desktop",
  "productName": "AiziD",
  "version": "1.0.0",
  "description": "Gabungin Google Drive Aggregator",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.gabungin.desktop",
    "win": {
      "target": "nsis"
    },
    "extraResources": [
      {
        "from": "../dist/app",
        "to": "app",
        "filter": [
          "**/*"
        ]
      }
    ]
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  }
}
